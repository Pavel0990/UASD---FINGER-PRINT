generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Catálogos ----------

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isDefault Boolean  @default(false) @map("is_default")
  employees Employee[]

  @@map("departments")
}

model EmployeeStatus {
  id        Int      @id @default(autoincrement())
  code      String   @unique // 'ok' | 'pending' | 'inactive' | custom
  label     String
  color     String?
  isDefault Boolean  @default(false) @map("is_default")
  employees Employee[]

  @@map("employee_statuses")
}

model Permission {
  id             String           @id // 'enroll' | 'reports' | 'manage' | ...
  labelEs        String           @map("label_es")
  labelEn        String           @map("label_en")
  rolePermissions RolePermission[]

  @@map("permissions")
}

// ---------- Empleados ----------

model Employee {
  id               String    @id // 'EMP-#####'
  name             String
  cedula           String    @unique
  departmentId     Int?      @map("department_id")
  department       Department? @relation(fields: [departmentId], references: [id])
  roleTitle        String?   @map("role_title") // "cargo" libre, no confundir con Role administrativo
  email            String    @unique // normalizado a lowercase en la capa de servicio
  phone            String?
  schedule         String?
  workDays         Int[]     @map("work_days")
  statusId         Int       @map("status_id")
  status           EmployeeStatus @relation(fields: [statusId], references: [id])
  inactiveReason   String?   @map("inactive_reason")
  inactiveComment  String?   @map("inactive_comment")
  dob              DateTime? @db.Date
  gender           String?   @db.Char(1)
  photoUrl         String?   @map("photo_url")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  credential          Credential?
  refreshTokens       RefreshToken[]
  roleAssignment      RoleAssignment?
  auditActions        AuditLog[]           @relation("AuditActor")
  auditSubjects       AuditLog[]           @relation("AuditSubject")
  attendanceEvents    AttendanceEvent[]
  absences            Absence[]
  webauthnCredentials WebauthnCredential[]
  rosterAssignments   RosterAssignment[]
  eventualities       Eventuality[]
  collectiveVacationAssignments CollectiveVacationAssignment[]

  @@map("employees")
}

// ---------- Credenciales / sesión ----------

model Credential {
  employeeId          String    @id @map("employee_id")
  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  passwordHash        String    @map("password_hash")
  mustChangePassword  Boolean   @default(true) @map("must_change_password")
  lastLoginAt         DateTime? @map("last_login_at")

  @@map("credentials")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  employeeId String    @map("employee_id")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tokenHash  String    @map("token_hash")
  issuedAt   DateTime  @default(now()) @map("issued_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  userAgent  String?   @map("user_agent")

  @@map("refresh_tokens")
}

// ---------- Roles / permisos ----------

model Role {
  id           String   @id // 'role_admin' | 'role_hr' | 'role_viewer' | custom
  name         String
  description  String?
  color        String?
  isProtected  Boolean  @default(false) @map("is_protected")
  maxMembers   Int?     @map("max_members")

  permissions  RolePermission[]
  assignments  RoleAssignment[]

  @@map("roles")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RoleAssignment {
  employeeId String   @id @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  roleId     String   @map("role_id")
  role       Role     @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@map("role_assignments")
}

// ---------- Asistencia / WebAuthn / Feriados (Fase 2) ----------

model AttendanceEvent {
  id          BigInt    @id @default(autoincrement())
  employeeId  String    @map("employee_id")
  employee    Employee  @relation(fields: [employeeId], references: [id])
  date        DateTime  @db.Date
  timeIn      DateTime? @map("time_in")
  timeOut     DateTime? @map("time_out")
  late        Boolean   @default(false)
  source      String    @default("kiosk") // 'kiosk' | 'finca' | 'liceo'
  justified   Boolean   @default(false)
  justifyNote String?   @map("justify_note")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([employeeId, date])
  @@map("attendance_events")
}

model Absence {
  id          BigInt    @id @default(autoincrement())
  employeeId  String    @map("employee_id")
  employee    Employee  @relation(fields: [employeeId], references: [id])
  date        DateTime  @db.Date
  justified   Boolean   @default(false)
  justifyNote String?   @map("justify_note")
  source      String?   // 'finca' | 'liceo' | 'eventualidad' | null (manual admin)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([employeeId, date])
  @@map("absences")
}

model WebauthnCredential {
  id          String    @id // credentialId, base64url
  employeeId  String    @map("employee_id")
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  publicKey   Bytes     @map("public_key")
  signCount   Int       @default(0) @map("sign_count")
  transports  String[]
  deviceLabel String?   @map("device_label")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime? @map("last_used_at")

  @@map("webauthn_credentials")
}

model WebauthnChallenge {
  id         String   @id @default(uuid())
  challenge  String   @unique
  employeeId String?  @map("employee_id") // null en auth-options: aún no se sabe quién marca
  purpose    String   // 'register' | 'auth'
  expiresAt  DateTime @map("expires_at")

  @@map("webauthn_challenges")
}

model Holiday {
  id      Int      @id @default(autoincrement())
  date    DateTime @unique @db.Date
  nameEs  String   @map("name_es")
  nameEn  String   @map("name_en")
  type    String   // 'fixed' | 'uasd' | 'custom'
  removed Boolean  @default(false)

  @@map("holidays")
}

// ---------- Finca / Liceo (Fase 3) ----------

// finca.jsx y liceo.jsx son el mismo dominio de datos con distinto nombre de key en
// localStorage — se modelan como una sola tabla con `location` en vez de duplicar el modelo.
model RosterAssignment {
  id         Int      @id @default(autoincrement())
  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location   String   // 'finca' | 'liceo'
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([employeeId, location])
  @@map("roster_assignments")
}

// ---------- Eventualidades / Vacaciones (Fase 4) ----------

// Unifica "Eventualidad" y "Vacaciones normales" de dashboard.jsx — eran el mismo efecto
// secundario sobre ausencias, código casi idéntico; la única diferencia real era que
// vacaciones normales no tenía type/estado. Acá 'vacaciones' es un valor más de `type`.
model Eventuality {
  id           Int       @id @default(autoincrement())
  employeeId   String    @map("employee_id")
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dateStart    DateTime  @map("date_start") @db.Date
  dateEnd      DateTime  @map("date_end") @db.Date
  type         String    // 'eventualidad'|'dia_libre'|'permiso'|'servicio_feriado'|'vacaciones'|custom
  motivo       String
  estado       String    @default("pendiente") // 'pendiente'|'aceptado'|'rechazado'
  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("eventualities")
}

// Vacaciones Colectivas — período anual global + roster de empleados asignados, sin efecto
// sobre ausencias (dominio aparte, confirmado en la investigación: vacaciones.jsx nunca
// toca uasd_absences).
model CollectiveVacationPeriod {
  id          Int      @id @default(autoincrement())
  year        Int      @unique
  createdAt   DateTime @default(now()) @map("created_at")
  days        CollectiveVacationDay[]
  assignments CollectiveVacationAssignment[]

  @@map("collective_vacation_periods")
}

model CollectiveVacationDay {
  id       Int      @id @default(autoincrement())
  periodId Int      @map("period_id")
  period   CollectiveVacationPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date

  @@unique([periodId, date])
  @@map("collective_vacation_days")
}

model CollectiveVacationAssignment {
  id         Int      @id @default(autoincrement())
  periodId   Int      @map("period_id")
  period     CollectiveVacationPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([periodId, employeeId])
  @@map("collective_vacation_assignments")
}

// ---------- Auditoría ----------

model AuditLog {
  id                 BigInt   @id @default(autoincrement())
  ts                 DateTime @default(now())
  actorEmployeeId    String   @map("actor_employee_id")
  actor              Employee @relation("AuditActor", fields: [actorEmployeeId], references: [id])
  actionType         String   @map("action_type") // 'add' | 'edit' | 'delete'
  subjectEmployeeId  String?  @map("subject_employee_id")
  subject            Employee? @relation("AuditSubject", fields: [subjectEmployeeId], references: [id])
  subjectLabel       String?  @map("subject_label")
  detail             Json?

  @@map("audit_log")
}

// ---------- Configuración global ----------

// Fila única (singleton, id fijo = 1) — no hay UI de "Configuración" completa
// todavía, así que se modela como una sola tabla en vez de un esquema
// clave/valor genérico. El umbral vive acá en vez de hardcodeado en
// attendance.service.js/kiosk.jsx para poder ajustarlo sin tocar código.
model SystemConfig {
  id                   Int @id @default(1)
  lateThresholdMinutes Int @default(15) @map("late_threshold_minutes")

  @@map("system_config")
}
